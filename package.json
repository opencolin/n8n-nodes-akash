{
  "name": "n8n-nodes-akash",
  "version": "1.0.1",
  "description": "n8n community node for Akash Network (akash.network) \u2014 decentralized cloud compute: deployments, leases, providers, and marketplace queries",
  "keywords": [
    "n8n-community-node-package",
    "akash",
    "akt",
    "depin",
    "decentralized-cloud",
    "deployment"
  ],
  "license": "MIT",
  "homepage": "https://akash.network/docs",
  "author": {
    "name": "Colin",
    "email": "collin@dabl.club"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opencolin/n8n-nodes-akash.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "jest",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/AkashApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Akash/Akash.node.js",
      "dist/nodes/AkashTrigger/AkashTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}